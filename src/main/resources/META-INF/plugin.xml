<idea-plugin require-restart="false">

    <id>com.palanquinsoftware.tova</id>
    <name>Tova</name>

    <vendor url="https://palanquinsoftware.com">Palanquin Software</vendor>

    <description><![CDATA[
        Language support for Tova...
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">

        <fileType
            name="Tova"
            implementationClass="com.palanquinsoftware.tova.TovaFileType"
            fieldName="INSTANCE"
            language="Tova"
            extensions="tova"/>

        <lang.parserDefinition
            language="Tova"
            implementationClass="com.palanquinsoftware.tova.TovaParserDefinition"/>

        <lang.syntaxHighlighterFactory
            language="Tova"
            implementationClass="com.palanquinsoftware.tova.TovaSyntaxHighlighterFactory"/>

        <lang.braceMatcher
            language="Tova"
            implementationClass="com.palanquinsoftware.tova.TovaBraceMatcher"/>

        <lang.commenter
            language="Tova"
            implementationClass="com.palanquinsoftware.tova.TovaCommenter"/>

        <completion.contributor
            language="Tova"
            implementationClass="com.palanquinsoftware.tova.TovaCompletionContributor"/>

        <colorSettingsPage
            implementation="com.palanquinsoftware.tova.TovaColorSettingsPage"/>

    </extensions>

</idea-plugin>
